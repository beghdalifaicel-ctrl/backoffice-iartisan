generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── CLIENTS (artisans abonnés) ──────────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Identité
  firstName     String
  lastName      String
  email         String   @unique
  phone         String?

  // Entreprise
  company       String
  metier        String          // plombier, electricien, etc.
  siret         String?
  ville         String
  codePostal    String?
  adresse       String?

  // Abonnement
  plan          Plan     @default(ESSENTIEL)
  status        ClientStatus @default(TRIAL)
  trialEndsAt   DateTime?

  // Stripe
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Google Business
  googleBusinessUrl    String?
  googleRating         Float?
  googleReviewCount    Int      @default(0)

  // Authentification client
  passwordHash         String?

  // Site vitrine
  siteUrl              String?
  sitePublished        Boolean  @default(false)

  // Onboarding
  onboarding_completed Boolean @default(false)

  // Relations
  leads       Lead[]
  invoices    Invoice[]
  messages    Message[]
  avis        Avis[]

  // Devis & Factures BTP
  customers   CustomerContact[]
  devis       Devis[]
  factures    Facture[]
  articles    Article[]

  // Agent IA → accédé via raw SQL (tables gérées hors Prisma)

  @@map("clients")
}

enum Plan {
  ESSENTIEL
  CROISSANCE
  PILOTE_AUTO
}

enum ClientStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CHURNED
  PAUSED
}

// ─── LEADS (prospects des artisans) ──────────────────────────────────────────

model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  // Contact
  name        String
  phone       String?
  email       String?

  // Besoin
  type        String          // "Dépannage", "Installation", "Rénovation"...
  message     String?

  // Source
  source      LeadSource @default(FORM)

  // Suivi
  status      LeadStatus @default(NEW)
  notes       String?

  // Client artisan qui reçoit ce lead
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  @@map("leads")
}

enum LeadSource {
  GOOGLE_ADS
  GOOGLE_BUSINESS
  SITE_VITRINE
  FORM
  WHATSAPP
}

enum LeadStatus {
  NEW
  CONTACTED
  RDV_BOOKED
  WON
  LOST
}

// ─── FACTURES ────────────────────────────────────────────────────────────────

model Invoice {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  number        String   @unique    // FAC-2026-001
  amount        Int                 // en centimes
  status        InvoiceStatus @default(PENDING)
  paidAt        DateTime?

  // Stripe
  stripeInvoiceId String? @unique
  stripePaymentUrl String?

  // Client
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  PAST_DUE
  VOID
}

// ─── AVIS GOOGLE ─────────────────────────────────────────────────────────────

model Avis {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  authorName  String
  rating      Int         // 1-5
  text        String?
  replied     Boolean  @default(false)
  replyText   String?

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  @@map("avis")
}

// ─── MESSAGES (chat conseiller ↔ client) ─────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  content     String
  fromAdmin   Boolean  @default(false)  // true = conseiller, false = client
  read        Boolean  @default(false)

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  @@map("messages")
}

// ─── LEADS FORMULAIRE SITE (avant d'avoir un client assigné) ─────────────────

model SiteLead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  // Artisan qui s'inscrit sur iartisan.io
  firstName   String
  lastName    String
  email       String
  phone       String?
  company     String?
  metier      String
  ville       String
  source      String?

  // Offre choisie
  plan        Plan     @default(ESSENTIEL)

  // Suivi
  status      SiteLeadStatus @default(NEW)
  notes       String?
  convertedToClientId String?

  @@map("site_leads")
}

enum SiteLeadStatus {
  NEW
  CONTACTED
  DEMO_BOOKED
  CONVERTED
  LOST
}

// ═══════════════════════════════════════════════════════════════════════════════
// DEVIS & FACTURES BTP (outil concurrent d'OBAT)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── CONTACTS CLIENTS DE L'ARTISAN ──────────────────────────────────────────

model CustomerContact {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Identité
  type        CustomerType @default(PARTICULIER)
  name        String
  email       String?
  phone       String?

  // Adresse
  adresse     String?
  codePostal  String?
  ville       String?

  // Entreprise (si pro)
  siret       String?
  tvaIntra    String?

  // Artisan propriétaire
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  // Relations
  devis       Devis[]
  factures    Facture[]

  @@map("customer_contacts")
}

enum CustomerType {
  PARTICULIER
  PROFESSIONNEL
}

// ─── DEVIS ──────────────────────────────────────────────────────────────────

model Devis {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Numérotation
  number        String   @unique    // DEV-2026-0001

  // Objet
  objet         String              // "Rénovation salle de bain"

  // Validité
  validUntil    DateTime?

  // Statut
  status        DevisStatus @default(BROUILLON)

  // Conditions
  conditions    String?              // Conditions de paiement
  notes         String?              // Notes internes

  // Remise globale
  remisePercent Float     @default(0)

  // Totaux calculés (stockés pour perf)
  totalHT       Float     @default(0)
  totalTVA      Float     @default(0)
  totalTTC      Float     @default(0)

  // Relations
  customerId    String
  customer      CustomerContact @relation(fields: [customerId], references: [id])
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  lots          DevisLot[]
  factures      Facture[]

  @@map("devis")
}

enum DevisStatus {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

// ─── LOTS (sections d'un devis) ─────────────────────────────────────────────

model DevisLot {
  id          String   @id @default(cuid())

  // Position dans le devis
  position    Int      @default(0)

  // Titre du lot
  titre       String              // "Lot 1 - Plomberie"

  // Devis parent
  devisId     String
  devis       Devis    @relation(fields: [devisId], references: [id], onDelete: Cascade)

  // Lignes
  lignes      DevisLigne[]

  @@map("devis_lots")
}

// ─── LIGNES DE DEVIS ────────────────────────────────────────────────────────

model DevisLigne {
  id          String   @id @default(cuid())

  // Position
  position    Int      @default(0)

  // Détail
  designation String              // "Pose de carrelage 60x60"
  description String?             // description longue optionnelle

  // Quantité
  quantite    Float    @default(1)
  unite       String   @default("u") // u, m², ml, m³, h, forfait, kg, l

  // Prix
  prixUnitHT  Float    @default(0)

  // TVA
  tauxTVA     Float    @default(20) // 20, 10, 5.5, 0

  // Lot parent
  lotId       String
  lot         DevisLot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@map("devis_lignes")
}

// ─── FACTURES ARTISAN (pas Stripe) ──────────────────────────────────────────

model Facture {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Numérotation
  number        String   @unique    // FAC-2026-0001

  // Type
  type          FactureType @default(FACTURE)

  // Objet
  objet         String

  // Statut paiement
  status        FactureStatus @default(EN_ATTENTE)
  paidAt        DateTime?

  // Échéance
  echeance      DateTime?

  // Notes
  conditions    String?
  notes         String?

  // Remise
  remisePercent Float     @default(0)

  // Totaux
  totalHT       Float     @default(0)
  totalTVA      Float     @default(0)
  totalTTC      Float     @default(0)

  // Montant déjà payé (pour situations)
  montantPaye   Float     @default(0)

  // Relations
  customerId    String
  customer      CustomerContact @relation(fields: [customerId], references: [id])
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  devisId       String?
  devis         Devis?   @relation(fields: [devisId], references: [id])
  lignes        FactureLigne[]

  @@map("factures")
}

enum FactureType {
  FACTURE
  ACOMPTE
  SITUATION
  AVOIR
}

enum FactureStatus {
  EN_ATTENTE
  PAYEE
  EN_RETARD
  ANNULEE
}

// ─── LIGNES DE FACTURE ──────────────────────────────────────────────────────

model FactureLigne {
  id          String   @id @default(cuid())

  position    Int      @default(0)
  lotTitre    String?             // Nom du lot (copié du devis)

  designation String
  description String?

  quantite    Float    @default(1)
  unite       String   @default("u")

  prixUnitHT  Float    @default(0)
  tauxTVA     Float    @default(20)

  factureId   String
  facture     Facture  @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@map("facture_lignes")
}

// ─── BIBLIOTHÈQUE ARTICLES ──────────────────────────────────────────────────

model Article {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Catégorie
  categorie   String?             // "Plomberie", "Électricité", "Peinture"

  // Détail
  designation String
  description String?

  // Prix par défaut
  unite       String   @default("u")
  prixUnitHT  Float    @default(0)
  tauxTVA     Float    @default(20)

  // Artisan propriétaire
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  @@map("articles")
}

// ═══════════════════════════════════════════════════════════════════════════════
// TABLES GÉRÉES HORS PRISMA (accédées via raw SQL)
// - materiaux_btp : base de données matériaux BTP partagée
// - agent_devis : devis générés par agents IA (Telegram, WhatsApp, SMS)
// Ces tables ont des enums PostgreSQL natifs incompatibles avec prisma generate.
// ═══════════════════════════════════════════════════════════════════════════════

