generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── CLIENTS (artisans abonnés) ──────────────────────────────────────────────

model Client {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Identité
  firstName     String
  lastName      String
  email         String   @unique
  phone         String?

  // Entreprise
  company       String
  metier        String          // plombier, electricien, etc.
  siret         String?
  ville         String
  codePostal    String?
  adresse       String?

  // Abonnement
  plan          Plan     @default(ESSENTIEL)
  status        ClientStatus @default(TRIAL)
  trialEndsAt   DateTime?

  // Stripe
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Google Business
  googleBusinessUrl    String?
  googleRating         Float?
  googleReviewCount    Int      @default(0)

  // Authentification client
  passwordHash         String?

  // Site vitrine
  siteUrl              String?
  sitePublished        Boolean  @default(false)

  // Onboarding
  onboarding_completed Boolean @default(false)

  // Relations
  leads       Lead[]
  invoices    Invoice[]
  messages    Message[]
  avis        Avis[]

  // Devis & Factures BTP : SUPPRIMÉS suite au pivot WhatsApp-first (01/05/2026).
  // Les devis générés par les agents IA (photo de chantier → PDF) restent
  // gérés hors Prisma dans la table `agent_devis` (cf. note en bas du fichier).

  // Bibliothèque tarifaire CONSERVÉE — Marie / Samir s'en servent pour
  // générer des devis cohérents (prix unitaires HT, TVA par catégorie).
  // Plus exposée via UI web mais consultée/enrichie par les agents IA.
  articles    Article[]

  // Agent IA → accédé via raw SQL (tables gérées hors Prisma)

  @@map("clients")
}

enum Plan {
  ESSENTIEL
  PRO        // ex-CROISSANCE
  MAX        // ex-PILOTE_AUTO
}

enum ClientStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CHURNED
  PAUSED
}

// ─── LEADS (prospects des artisans) ──────────────────────────────────────────

model Lead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  // Contact
  name        String
  phone       String?
  email       String?

  // Besoin
  type        String          // "Dépannage", "Installation", "Rénovation"...
  message     String?

  // Source
  source      LeadSource @default(FORM)

  // Suivi
  status      LeadStatus @default(NEW)
  notes       String?

  // Client artisan qui reçoit ce lead
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  @@map("leads")
}

enum LeadSource {
  GOOGLE_ADS
  GOOGLE_BUSINESS
  SITE_VITRINE
  FORM
  WHATSAPP
}

enum LeadStatus {
  NEW
  CONTACTED
  RDV_BOOKED
  WON
  LOST
}

// ─── FACTURES ────────────────────────────────────────────────────────────────

model Invoice {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  number        String   @unique    // FAC-2026-001
  amount        Int                 // en centimes
  status        InvoiceStatus @default(PENDING)
  paidAt        DateTime?

  // Stripe
  stripeInvoiceId String? @unique
  stripePaymentUrl String?

  // Client
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  PAST_DUE
  VOID
}

// ─── AVIS GOOGLE ─────────────────────────────────────────────────────────────

model Avis {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  authorName  String
  rating      Int         // 1-5
  text        String?
  replied     Boolean  @default(false)
  replyText   String?

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  @@map("avis")
}

// ─── MESSAGES (chat conseiller ↔ client) ─────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  content     String
  fromAdmin   Boolean  @default(false)  // true = conseiller, false = client
  read        Boolean  @default(false)

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  @@map("messages")
}

// ─── LEADS FORMULAIRE SITE (avant d'avoir un client assigné) ─────────────────

model SiteLead {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  // Artisan qui s'inscrit sur iartisan.io
  firstName   String
  lastName    String
  email       String
  phone       String?
  company     String?
  metier      String
  ville       String
  source      String?

  // Offre choisie
  plan        Plan     @default(ESSENTIEL)

  // Suivi
  status      SiteLeadStatus @default(NEW)
  notes       String?
  convertedToClientId String?

  @@map("site_leads")
}

enum SiteLeadStatus {
  NEW
  CONTACTED
  DEMO_BOOKED
  CONVERTED
  LOST
}

// ═══════════════════════════════════════════════════════════════════════════════
// MODÈLES BTP SUPPRIMÉS (pivot WhatsApp-first, 01/05/2026)
// ═══════════════════════════════════════════════════════════════════════════════
// Les modèles suivants ont été supprimés car iArtisan ne concurrence plus
// les outils de gestion de devis/factures BTP (Obat, Tolteck, Henrri) :
//   - CustomerContact, Devis, DevisLot, DevisLigne
//   - Facture, FactureLigne
//   - enums : CustomerType, DevisStatus, FactureType, FactureStatus
//
// CONSERVÉS pour les agents IA :
//   - Article (bibliothèque tarifaire) : Marie/Samir consultent et enrichissent
//     pour générer des devis cohérents (prix unitaire HT, TVA par catégorie).
//
// La migration de drop est dans prisma/migrations/20260503_drop_btp_models/
//
// Les devis générés par Marie via photo/texte → PDF restent fonctionnels et
// sont stockés dans la table `agent_devis` (hors Prisma, raw SQL).
// ═══════════════════════════════════════════════════════════════════════════════

// ─── BIBLIOTHÈQUE ARTICLES (consultée par les agents IA) ───────────────────

model Article {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Catégorie
  categorie   String?             // "Plomberie", "Électricité", "Peinture"

  // Détail
  designation String
  description String?

  // Prix par défaut
  unite       String   @default("u")
  prixUnitHT  Float    @default(0)
  tauxTVA     Float    @default(20)

  // Artisan propriétaire
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  @@map("articles")
}

// ═══════════════════════════════════════════════════════════════════════════════
// TABLES GÉRÉES HORS PRISMA (accédées via raw SQL)
// - materiaux_btp : base de données matériaux BTP partagée (référence prix)
// - agent_devis : devis générés par agents IA via WhatsApp (photo, texte)
// Ces tables ont des enums PostgreSQL natifs incompatibles avec prisma generate.
// Marie et Samir consultent materiaux_btp pour les prix de référence et
// agent_devis pour l'historique des devis envoyés à un client.
// ═══════════════════════════════════════════════════════════════════════════════

