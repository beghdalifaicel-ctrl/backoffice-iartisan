STRIPE_PAYMENT_LINK_PRO="https://buy.stripe.com/..."
STRIPE_PAYMENT_LINK_MAX="https://buy.stripe.com/..."

# ─── WhatsApp Business API (Meta Cloud) ───
WHATSAPP_VERIFY_TOKEN="iartisan-whatsapp-verify"
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ─── LLM (Anthropic Claude + Groq Whisper pour vocaux) ───
ANTHROPIC_API_KEY="sk-ant-..."
GROQ_API_KEY="gsk_..."

# ─── Email (Resend) ───
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@iartisan.io"
