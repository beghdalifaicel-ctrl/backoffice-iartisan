# ─── Auth Admin (backoffice Faicel) ───
ADMIN_EMAIL="faicel@iartisan.io"
ADMIN_PASSWORD_HASH=""
JWT_SECRET="your-random-secret-key-min-32-chars"

# ─── Sécurité endpoints internes ───
# Secret à fournir dans le header x-internal-secret pour les endpoints
# appelés uniquement par le bot WhatsApp (ex: /api/client/billing/portal)
INTERNAL_API_SECRET="generate-random-min-32-chars"

# ─── App ───
NEXT_PUBLIC_APP_URL="https://app.iartisan.io"
NEXT_PUBLIC_SITE_URL="https://iartisan.io"

# ─── Google My Business (OAuth) ───
GMB_CLIENT_ID=""
GMB_CLIENT_SECRET=""
GMB_REDIRECT_URI="https://app.iartisan.io/api/oauth/gmb/cb"

